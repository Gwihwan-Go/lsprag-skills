#!/usr/bin/env bash
# lsprag — LSP-based code analysis CLI for AI agents
#
# Install: bash ~/.lsprag-skills/install.sh
# Or manually symlink: ln -sf ~/.lsprag-skills/scripts/lsprag ~/.local/bin/lsprag
#
# The LSPRAG_SKILLS_ROOT env var is used to locate core modules.
# Falls back to the directory containing this script's real location.

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
ROOT="${LSPRAG_SKILLS_ROOT:-$(cd "$SCRIPT_DIR/.." && pwd)}"

# Auto-detect LSP provider if not explicitly set
# Prefer lsp-client.ts (real LSP via pyright/tsserver/gopls) over jedi bridge
if [ -z "$LSPRAG_LSP_PROVIDER" ] && [ -f "$ROOT/providers/lsp-client.ts" ]; then
  export LSPRAG_LSP_PROVIDER="$ROOT/providers/lsp-client.ts"
elif [ -z "$LSPRAG_LSP_PROVIDER" ] && [ -f "$ROOT/providers/jedi-provider.mjs" ]; then
  export LSPRAG_LSP_PROVIDER="$ROOT/providers/jedi-provider.mjs"
fi

CMD="${1:-}"
shift 2>/dev/null || true

case "$CMD" in
  def-tree)
    echo "lsprag: def-tree is temporarily disabled." >&2
    echo "Use getDefinition, getTokens, or deep-think instead." >&2
    exit 2
    ;;
  getDefinition)
    exec npx --prefix "$ROOT" tsx "$ROOT/scripts/get-definition-cli.ts" "$@"
    ;;
  retrieve-def)
    exec npx --prefix "$ROOT" tsx "$ROOT/scripts/retrieve-def-cli.ts" "$@"
    ;;
  getTokens)
    exec npx --prefix "$ROOT" tsx "$ROOT/scripts/get-tokens-cli.ts" "$@"
    ;;
  token-defs)
    exec npx --prefix "$ROOT" tsx "$ROOT/scripts/token-defs-cli.ts" "$@"
    ;;
  token-analysis)
    exec npx --prefix "$ROOT" tsx "$ROOT/scripts/token-defs-cli.ts" "$@" --analysis --format markdown
    ;;
  getReference)
    exec npx --prefix "$ROOT" tsx "$ROOT/scripts/get-reference-cli.ts" "$@"
    ;;
  listSymbols)
    exec npx --prefix "$ROOT" tsx "$ROOT/scripts/list-symbols-cli.ts" "$@"
    ;;
  callChain)
    exec npx --prefix "$ROOT" tsx "$ROOT/scripts/call-hierarchy-cli.ts" --direction incoming "$@"
    ;;
  callHierarchy)
    exec npx --prefix "$ROOT" tsx "$ROOT/scripts/call-hierarchy-cli.ts" "$@"
    ;;
  deep-think)
    exec npx --prefix "$ROOT" tsx "$ROOT/scripts/deep-think-cli.ts" "$@"
    ;;
  version|--version|-V)
    echo "lsprag 0.2.0 (root: $ROOT)"
    ;;
  help|--help|-h|"")
    cat <<'HELP'
lsprag — LSP-based code analysis for AI agents

Usage:
  lsprag <command> [options]

Commands:
  listSymbols     List all functions, classes, and symbols in a file
  getDefinition   Get the full source of a symbol's definition (hover for variables/constants)
  getTokens       List tokens inside a symbol with their definition locations
  getReference    Find all callers/usages of a symbol
  callChain       Trace incoming call chain (who calls this, recursively)
  callHierarchy   Show incoming/outgoing call hierarchy (both directions)
  deep-think      BFS expansion: retrieve source + deps for a symbol and all dependencies

Options:
  -h, --help      Show this help
  --version       Show version

Run 'lsprag <command> --help' for command-specific options.

Examples:
  lsprag listSymbols    --file "$(realpath src/server.ts)"
  lsprag getDefinition  --file "$(realpath src/server.ts)" --symbol handleRequest
  lsprag getTokens      --file "$(realpath src/server.ts)" --symbol handleRequest
  lsprag getReference   --file "$(realpath src/server.ts)" --symbol handleRequest
  lsprag callChain      --file "$(realpath src/server.ts)" --symbol handleRequest
  lsprag deep-think     --file "$(realpath src/server.ts)" --symbol handleRequest --depth 2
HELP
    ;;
  *)
    echo "lsprag: unknown command '$CMD'" >&2
    echo "Run 'lsprag help' for usage." >&2
    exit 1
    ;;
esac
