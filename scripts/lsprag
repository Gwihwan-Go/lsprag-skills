#!/usr/bin/env bash
# lsprag — LSP-based code analysis CLI for AI agents
#
# Install: bash ~/.lsprag-skills/install.sh
# Or manually symlink: ln -sf ~/.lsprag-skills/scripts/lsprag ~/.local/bin/lsprag
#
# The LSPRAG_SKILLS_ROOT env var is used to locate core modules.
# Falls back to the directory containing this script's real location.

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
ROOT="${LSPRAG_SKILLS_ROOT:-$(cd "$SCRIPT_DIR/.." && pwd)}"

CMD="${1:-}"
shift 2>/dev/null || true

case "$CMD" in
  def-tree|deftree|tree)
    echo "lsprag: command 'def-tree' is temporarily disabled." >&2
    echo "Use 'retrieve-def', 'token-defs', or 'deep-think' instead." >&2
    exit 2
    ;;
  retrieve-def|retrieve|def)
    exec npx --prefix "$ROOT" tsx "$ROOT/scripts/retrieve-def-cli.ts" "$@"
    ;;
  token-defs|tokendefs|tokens)
    exec npx --prefix "$ROOT" tsx "$ROOT/scripts/token-defs-cli.ts" "$@"
    ;;
  token-analysis|token_analysis|tokenanalysis|analysis)
    exec npx --prefix "$ROOT" tsx "$ROOT/scripts/token-defs-cli.ts" --analysis --full-source --format markdown "$@"
    ;;
  deep-think|deepthink|think)
    exec npx --prefix "$ROOT" tsx "$ROOT/scripts/deep-think-cli.ts" "$@"
    ;;
  version|--version|-V)
    echo "lsprag 0.1.0 (root: $ROOT)"
    ;;
  help|--help|-h|"")
    cat <<'HELP'
lsprag — LSP-based code analysis for AI agents

Usage:
  lsprag <command> [options]

Commands:
  def-tree      Temporarily disabled
  retrieve-def  Get the full source of a symbol's definition
  token-defs    List tokens inside a symbol with their definition locations
  token-analysis Run token-defs in analysis mode (markdown links + definition sources)
  deep-think    BFS expansion: retrieve source + deps for a symbol and all dependencies

Options:
  -h, --help      Show this help
  --version       Show version

Run 'lsprag <command> --help' for command-specific options.

Examples:
  lsprag retrieve-def --file src/server.ts   --symbol handleRequest
  lsprag retrieve-def --file src/server.ts   --symbol parseBody,readStream
  lsprag retrieve-def --file src/server.ts   --location 42:15
  lsprag retrieve-def --file src/server.ts   --line-range 120:180
  lsprag token-defs   --file src/server.ts   --symbol handleRequest
  lsprag token-analysis --file src/server.ts --symbol handleRequest
  lsprag deep-think   --file src/server.ts   --symbol handleRequest --depth 2
HELP
    ;;
  *)
    echo "lsprag: unknown command '$CMD'" >&2
    echo "Run 'lsprag help' for usage." >&2
    exit 1
    ;;
esac
